<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <!-- Lite MSI: no embedded .NET / VC++ redist; InstallPrereqs.ps1 downloads from Microsoft at install time. -->
  <Package Name="NeathCopy (Lite)"
           Manufacturer="Eneleich"
           Version="1.0.0"
           UpgradeCode="{E1F2A3B4-C5D6-4789-0123-456789ABCDEF}"
           Compressed="yes"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of NeathCopy (Lite) is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Icon Id="NeathCopyIcon" SourceFile="..\..\Target\neathcopy.ico" />
    <Property Id="ARPPRODUCTICON" Value="NeathCopyIcon" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch NeathCopy now" />
    <WixVariable Id="WixUILicenseRtf" Value="License-MIT.rtf" />

    <Property Id="ARPCONTACT" Value="Nestor" />
    <Property Id="ARPCOMMENTS" Value="NeathCopy Lite — prerequisites download on install (smaller MSI)." />
    <Property Id="ARPHELPTELEPHONE" Value="+1 786-865-3213" />

    <Property Id="NETFRAMEWORK48_RELEASE">
      <RegistrySearch Id="NetFx48Release"
                      Root="HKLM"
                      Key="SOFTWARE\Microsoft\NET Framework Setup\NDP\v4\Full"
                      Name="Release"
                      Type="raw" />
    </Property>
    <Property Id="VCRUNTIME_X64_INSTALLED">
      <RegistrySearch Id="VcRuntimeX64Installed"
                      Root="HKLM"
                      Key="SOFTWARE\Microsoft\VisualStudio\14.0\VC\Runtimes\x64"
                      Name="Installed"
                      Type="raw" />
    </Property>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="NeathCopy">
        <Directory Id="SOUNDSFOLDER" Name="Sounds" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppProgramsFolder" Name="NeathCopy" />
    </StandardDirectory>

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="DirCommonStartupMsft" Name="Microsoft">
        <Directory Id="DirCommonStartupWin" Name="Windows">
          <Directory Id="DirCommonStartupMenu" Name="Start Menu">
            <Directory Id="DirCommonStartupPrograms" Name="Programs">
              <Directory Id="AllUsersStartupFolder" Name="StartUp">
                <Component Id="NeathCopyCommonStartupTray" Guid="C9E8D7F6-A5B4-3210-9876-543210FEDCBA">
                  <Shortcut Id="NeathCopyTrayCommonStartupShortcut"
                            Directory="AllUsersStartupFolder"
                            Name="NeathCopy Tray"
                            Target="[#NeathCopyExeFile]"
                            WorkingDirectory="INSTALLFOLDER"
                            Arguments="--tray"
                            Icon="NeathCopyIcon"
                            IconIndex="0" />
                  <RegistryValue Root="HKLM"
                                 Key="Software\Eneleich\NeathCopy"
                                 Name="CommonStartupTrayInstalledLite"
                                 Type="integer"
                                 Value="1"
                                 KeyPath="yes" />
                </Component>
              </Directory>
            </Directory>
          </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>

    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="NeathCopyMainExecutable" Guid="*">
        <File Id="NeathCopyExeFile" Source="..\..\Target\Release\NeathCopy.exe" KeyPath="yes" />
      </Component>

      <Component Id="NeathCopyShortcuts" Guid="*">
        <Shortcut Id="NeathCopyStartMenuShortcut"
                  Directory="AppProgramsFolder"
                  Name="NeathCopy"
                  Target="[#NeathCopyExeFile]"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="NeathCopyIcon"
                  IconIndex="0" />
        <RegistryValue Root="HKCU"
                       Key="Software\Eneleich\NeathCopy"
                       Name="ShortcutsInstalledLite"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>

      <Component Id="NeathCopyMachineRegistry" Guid="D0E1F2A3-B4C5-4657-8901-23456789ABCD">
        <RegistryKey Root="HKLM" Key="Software\Eneleich\NeathCopy">
          <RegistryValue Type="string" Name="InstallDir" Value="[INSTALLFOLDER]" />
          <RegistryValue Type="string" Name="CopyHandler" Value="[INSTALLFOLDER]NeathCopy.exe" />
          <RegistryValue Type="string" Name="FilesList" Value="C:\Users\Public\AppData\NeathCopy\FilesList.txt" />
          <RegistryValue Type="string" Name="LogsDir" Value="C:\Users\Public\AppData\NeathCopy" />
          <RegistryValue Type="string" Name="IsDefaultCopyHandler" Value="1" />
          <RegistryValue Type="string" Name="IntegrationMode" Value="TrayIPC" />
        </RegistryKey>
        <RegistryValue Root="HKLM"
                       Key="Software\Eneleich\NeathCopy"
                       Name="MachineDefaultsInstalledLite"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>

      <Component Id="NeathCopyRootFiles" Guid="{82D609E4-6AFD-4E0E-B291-C31213DE19F3}">
        <File Source="..\..\Target\Release\NeathCopy.AdminHelper.exe" />
        <File Source="..\..\Target\Release\NeathCopyEngine.dll" />
        <File Source="..\..\Target\Release\NeathCopy.exe.config" />
        <File Source="..\..\Target\Release\NeathCopy.exe.manifest" />
        <File Source="..\..\Target\Release\x64\NeathCopyShell.dll" SelfRegCost="1" />
        <File Source="..\..\Target\neathcopy.ico" />
      </Component>

      <!-- Scripts run deferred (elevated) to download .NET 4.8 web bootstrapper and VC++ x64 from Microsoft. -->
      <Component Id="PrereqScripts" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567893">
        <File Id="InstallPrereqsCmd" Source="InstallPrereqs.cmd" KeyPath="yes" />
        <File Id="InstallPrereqsPs1" Source="InstallPrereqs.ps1" />
      </Component>

      <Component Id="RegistryDefaults" Guid="*">
        <RegistryKey Root="HKLM" Key="Software\Eneleich" />

        <RegistryKey Root="HKCU" Key="Software\Eneleich\NeathCopy">
          <RegistryValue Name="LogsDir" Type="string" Value="C:\Users\Public\AppData\NeathCopy" />
          <RegistryValue Name="ShellDebugMode" Type="string" Value="file" />
          <RegistryValue Name="InstallDir" Type="string" Value="C:\Program Files\NeathCopy\" />
          <RegistryValue Name="ShellDebugVerbosity" Type="integer" Value="0" />
          <RegistryValue Name="FilesList" Type="string" Value="C:\Users\Public\AppData\NeathCopy\FilesList.txt" />
          <RegistryValue Name="Handle" Type="string" Value="0" />
          <RegistryValue Name="CopyHandler" Type="string" Value="C:\Program Files\NeathCopy\\NeathCopy.exe" />
          <RegistryValue Name="ShellDebugEventLog" Type="integer" Value="0" />
          <RegistryValue Name="ExistConfig" Type="string" Value="1" />
          <RegistryValue Name="ShellDebug" Type="integer" Value="0" />
          <RegistryValue Name="IsDefaultCopyHandler" Type="string" Value="1" />
          <RegistryValue Name="Exist" Type="string" Value="0" />
        </RegistryKey>

        <RegistryKey Root="HKCU" Key="Software\Eneleich\NeathCopy\LastArguments">
          <RegistryValue Name="Operation" Type="string" Value="" />
          <RegistryValue Name="SourcesContainer" Type="string" Value="" />
          <RegistryValue Name="Source" Type="string" Value="" />
          <RegistryValue Name="Destiny" Type="string" Value="" />
        </RegistryKey>

        <RegistryKey Root="HKCU" Key="Software\Eneleich\NeathCopy\Settigs">
          <RegistryValue Name="PlaySound_After_Cancel" Type="string" Value="True" />
          <RegistryValue Name="AffterErrorAction" Type="string" Value="Close_AffterErrorAction" />
          <RegistryValue Name="VisualCopySkins" Type="string" Value="Windows8.xaml" />
          <RegistryValue Name="Language" Type="string" Value="English.xaml" />
          <RegistryValue Name="PlaySound_After_Finish" Type="string" Value="True" />
          <RegistryValue Name="BufferSize" Type="string" Value="262144" />
          <RegistryValue Name="Process_ADD_DATA" Type="string" Value="SameVolumen_Process_ADD_DATA" />
          <RegistryValue Name="PlaySound_After_ADD_DATA" Type="string" Value="False" />
          <RegistryValue Name="Font" Type="string" Value="Fonts1.xaml" />
          <RegistryValue Name="AddNewVisualCopy" Type="string" Value="SeparateWindows_AddNewVC" />
          <RegistryValue Name="SetRunningState" Type="string" Value="StartOperation_SetRunningState" />
          <RegistryValue Name="Theme" Type="string" Value="Windows8Theme.xaml" />
          <RegistryValue Name="UpdateTimeInterval" Type="string" Value="150" />
          <RegistryValue Name="FileCopier" Type="string" Value="CopyFileExFileCopier" />
          <RegistryValue Name="IntegrationMode" Type="string" Value="TrayIPC" />
          <RegistryValue Name="Brushes" Type="string" Value="Dark.xaml" />
        </RegistryKey>

        <RegistryValue Root="HKCU"
                       Key="Software\Eneleich\NeathCopy"
                       Name="InstalledByMsiLite"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <DirectoryRef Id="SOUNDSFOLDER">
      <Component Id="SoundFiles" Guid="{17A4CC7B-B0E7-4CF7-9FE9-CF82765D3E47}">
        <File Source="..\..\Target\Sounds\add data.wav" />
        <File Source="..\..\Target\Sounds\cancell.wav" />
        <File Source="..\..\Target\Sounds\task finished.wav" />
      </Component>
    </DirectoryRef>

    <DirectoryRef Id="AppProgramsFolder">
      <Component Id="ProgramsFolderCleanup" Guid="*">
        <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\Eneleich\NeathCopy"
                       Name="ProgramsFolderCreatedLite"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <CustomAction Id="DownloadPrereqs"
                  FileRef="InstallPrereqsCmd"
                  ExeCommand=""
                  Execute="deferred"
                  Return="ignore"
                  Impersonate="no" />

    <CustomAction Id="LaunchNeathCopy"
                  FileRef="NeathCopyExeFile"
                  ExeCommand=""
                  Return="asyncNoWait"
                  Execute="immediate"
                  Impersonate="yes" />

    <InstallExecuteSequence>
      <Custom Action="DownloadPrereqs"
              After="InstallFiles"
              Condition="NOT Installed AND ((NOT NETFRAMEWORK48_RELEASE OR NETFRAMEWORK48_RELEASE &lt; 528040) OR VCRUNTIME_X64_INSTALLED &lt;&gt; 1)" />
    </InstallExecuteSequence>

    <ui:WixUI Id="WixUI_InstallDir" />
    <UI>
      <Publish Dialog="ExitDialog"
               Control="Finish"
               Event="DoAction"
               Value="LaunchNeathCopy"
               Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT Installed" />
    </UI>

    <Feature Id="MainFeature" Title="NeathCopy (Lite)" Level="1">
      <ComponentRef Id="NeathCopyMainExecutable" />
      <ComponentRef Id="NeathCopyShortcuts" />
      <ComponentRef Id="NeathCopyCommonStartupTray" />
      <ComponentRef Id="NeathCopyMachineRegistry" />
      <ComponentRef Id="NeathCopyRootFiles" />
      <ComponentRef Id="PrereqScripts" />
      <ComponentRef Id="RegistryDefaults" />
      <ComponentRef Id="SoundFiles" />
      <ComponentRef Id="ProgramsFolderCleanup" />
    </Feature>
  </Package>
</Wix>
