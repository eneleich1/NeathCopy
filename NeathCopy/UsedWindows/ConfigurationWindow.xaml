<Window x:Class="NeathCopy.UsedWindows.ConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" Name="configWnd"
        xmlns:local="clr-namespace:NeathCopy.UsedWindows" MinHeight="380" MinWidth="480" Loaded="Window_Loaded" Closing="configWnd_Closing"
        mc:Ignorable="d" Style="{DynamicResource UsedWindowStyle}" SizeToContent="WidthAndHeight"  WindowStartupLocation="CenterOwner"
        Title="ConfigurationWindow" Icon="/NeathCopy;component/Brushes/Images/Light/settings.png">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Menu VerticalAlignment="Top" Margin="0,2,0,0" Background="{DynamicResource MenuBackground}">
            <MenuItem Header="{DynamicResource t59}" Name="fileMenu"/>
            <MenuItem Header="{DynamicResource t60}" Name="toolsMenu">
                <MenuItem Header="Video Conversion (FFmpeg)" Click="VideoConversionMenu_Click"/>
            </MenuItem>
        </Menu>
        <TabControl Grid.Row="1" Margin="5">
            <TabItem Header="{DynamicResource t97}" >
                <StackPanel Orientation="Vertical" Margin="10" Background="{DynamicResource ControlBackgroundBrush}">
                    <StackPanel Orientation="Horizontal">
                        <GroupBox Header="{DynamicResource t61}">
                            <StackPanel Margin="3">
                                <RadioButton Margin="0,3,0,0" Name="addToFirsth_rb" Content="{DynamicResource t62}" IsChecked="{Binding AddToFirsth}"/>
                                <RadioButton Margin="0,3,0,0" Name="addToLast_rb" Content="{DynamicResource t63}" IsChecked="{Binding AddToLast}"/>
                                <RadioButton Margin="0,3,0,0" Name="add_SameDestiny_rb"  Content="{DynamicResource t64}" IsChecked="{Binding AddToSameDestiny}" />
                                <RadioButton Margin="0,3,0,0" Name="add_SameVolumen_rb"   Content="{DynamicResource t65}" IsChecked="{Binding AddToSameVolumen}"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Margin="5,0,0,0" Header="{DynamicResource t66}">
                            <StackPanel Margin="3">
                                <RadioButton Margin="0,3,0,0" Name="sob_AutomatlyStart_rb" Content="{DynamicResource t67}" IsChecked="{Binding StartAutomatically}" />
                                <RadioButton Margin="0,3,0,0" Name="sob_WaitInQueve_rb" Content="{DynamicResource t68}" IsChecked="{Binding WaitInQueue}"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                    <Separator/>
                    <GroupBox Header="{DynamicResource t69}" HorizontalAlignment="Left">
                        <StackPanel Margin="3" Orientation="Horizontal">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource t70}"/>
                                <ComboBox Name="copyEngine_cb" Background="Transparent" Width="209"
                                          ItemsSource="{Binding FileCopiers}" SelectedItem="{Binding SelectedFileCopier}"/>
                            </StackPanel>
                            <Separator Width="30" Background="Transparent"/>
                            <StackPanel >
                                <TextBlock Text="{DynamicResource t71}"/>
                                <TextBox Width="105"  Name="bufferSize_textBox" HorizontalAlignment="Left" TextAlignment="Right"
                                         Text="{Binding BufferSizeText, UpdateSourceTrigger=PropertyChanged}"
                                         
                                         />
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                    <Separator/>
                    <StackPanel HorizontalAlignment="Left" Orientation="Horizontal" Height="90">
                        <GroupBox Header="{DynamicResource t72}" >
                            <StackPanel Margin="3">
                                <CheckBox Margin="0,3,0,0" Name="ps_affter_ADD_DATA_cb"  Content="{DynamicResource t73}" HorizontalAlignment="Left"
                                          IsChecked="{Binding PlaySoundAfterAddData}"/>
                                <CheckBox Margin="0,3,0,0" Name="ps_affter_Finish_cb"  Content="{DynamicResource t74}" HorizontalAlignment="Left"
                                          IsChecked="{Binding PlaySoundAfterFinish}"/>
                                <CheckBox Margin="0,3,0,0" Name="ps_When_Cancel_cb"  Content="{DynamicResource t75}" HorizontalAlignment="Left"
                                          IsChecked="{Binding PlaySoundAfterCancel}"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Margin="5,0,0,0" Header="{DynamicResource t76}">
                            <StackPanel Margin="3">
                                <RadioButton Margin="0,3,0,0" Name="ancb_All_In_One_rb" Content="{DynamicResource t77}" IsChecked="{Binding AllInOne}"/>
                                <RadioButton Margin="0,3,0,0" Name="ancb_Use_Separate_Windos_rb" Content="{DynamicResource t78}" IsChecked="{Binding SeparateWindows}" />
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                    <Separator/>
                    <StackPanel HorizontalAlignment="Left" Orientation="Horizontal" Height="90">
                        <GroupBox Margin="5,0,0,0" Header="{DynamicResource t117}">
                            <StackPanel Margin="3,3,30,3">
                                <RadioButton Margin="0,3,0,0" Name="closeAffterError_rb" Content="{DynamicResource t118}" IsChecked="{Binding CloseAfterError}"/>
                                <RadioButton Margin="0,3,0,0" Name="keepAffterError_rb" Content="{DynamicResource t119}" IsChecked="{Binding KeepAfterError}" />
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </StackPanel>
            </TabItem>
            <TabItem Header="{DynamicResource t79}" >
                <StackPanel Orientation="Vertical" Background="{DynamicResource ControlBackgroundBrush}">
                    <GroupBox Header="{DynamicResource t80}">
                        <StackPanel  Orientation="Horizontal">
                            <Label Content="{DynamicResource t81}" />
                            <ComboBox Name="language_cb" Width="160"  Height="23" SelectedIndex="0" Margin="3,0,0,0"
                                      ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource t82}" Margin="0,3,0,0">
                        <Canvas Margin="0" Height="130">
                            <StackPanel Canvas.Top="13" Canvas.Left="0">
                                <StackPanel Orientation="Horizontal" Grid.Row="0" Height="23">
                                    <TextBlock Text="{DynamicResource t83}" Width="130"/>
                                    <ComboBox Width="200" Name="theme_cb" SelectedIndex="0"
                                              ItemsSource="{Binding Themes}" SelectedItem="{Binding SelectedTheme}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Grid.Row="1" Height="23" Margin="0,5,0,5">
                                    <TextBlock Text="{DynamicResource t84}" Width="130"/>
                                    <ComboBox Width="200" Name="skins_cb"  SelectedIndex="0"
                                              ItemsSource="{Binding Skins}" SelectedItem="{Binding SelectedSkin}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Grid.Row="2" Height="23">
                                    <TextBlock Text="{DynamicResource t85}" Width="130"/>
                                    <ComboBox Width="200" Name="brushes_cb"  SelectedIndex="0"
                                              ItemsSource="{Binding Brushes}" SelectedItem="{Binding SelectedBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Grid.Row="2" Height="23" Margin="0,5,0,5">
                                    <TextBlock Text="{DynamicResource t86}" Width="130"/>
                                    <ComboBox Width="200" SelectedIndex="0" Name="font_cb"
                                              ItemsSource="{Binding Fonts}" SelectedItem="{Binding SelectedFont}"/>
                                </StackPanel>
                            </StackPanel>
                        </Canvas>
                    </GroupBox>
                    <GroupBox Header="{DynamicResource t87}">
                        <Grid>
                            <Control Margin="-10,-12,-10,-10" Name="skinControl" Width="409" Style="{DynamicResource VisualCopyStyle}" RenderTransformOrigin="0.5,0.5" >
                                <Control.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="0.7" ScaleY="0.7"/>
                                        <SkewTransform/>
                                        <RotateTransform/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </Control.RenderTransform>
                            </Control>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </TabItem>
            <TabItem Header="{DynamicResource t102}">
                <GroupBox Margin="10" Header="{DynamicResource t107}">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Content="{DynamicResource t103}"/>
                        <TextBox Name="updateTime_tb" Grid.Column="1" Width="60" Margin="3"
                                 Text="{Binding UpdateTimeText, UpdateSourceTrigger=PropertyChanged}"/>

                      
                    </Grid>
                </GroupBox>
            </TabItem>
            <TabItem Header="{DynamicResource t94}">
                <Grid Margin="10" Background="{DynamicResource ControlBackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.Resources>
                        <Style TargetType="TextBlock" x:Key="InfoLabelStyle">
                            <Setter Property="Width" Value="80"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            
                        </Style>
                    </Grid.Resources>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource t95}" Style="{StaticResource InfoLabelStyle}"/>
                        <TextBlock Text="Néstor Longa Henández"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Grid.Row="1">
                        <TextBlock Text="{DynamicResource t96}" Style="{StaticResource InfoLabelStyle}" />
                        <TextBlock Text="NeathCopy v3.8"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
