<Window x:Class="NeathCopy.UsedWindows.ScriptHooksWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Script Hooks"
        SizeToContent="WidthAndHeight"
        MinWidth="520"
        WindowStartupLocation="CenterOwner"
        Style="{DynamicResource UsedWindowStyle}">
    <Grid Margin="10"
          Background="{DynamicResource ControlBackgroundBrush}"
          TextElement.Foreground="{DynamicResource TextBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Background="{DynamicResource ControlBackgroundBrush}">
            <TextBlock Margin="0,0,0,8" TextWrapping="Wrap"
                       Text="Configure scripts or programs to run after copy completion. Placeholders: {Operation} {Source} {Dest} {Engine} {BufferSize} {FilesCount} {Bytes} {ElapsedMs} {SpeedBps} {ErrorsCount} {CancelCause}"/>

            <GroupBox Header="On Success" Margin="0,0,0,8">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <CheckBox x:Name="SuccessEnabledCheckBox" Content="Enable" Grid.Column="0" Grid.Row="0" Margin="0,0,8,6"/>
                    <CheckBox x:Name="SuccessIncludeContextCheckBox" Content="Include copy context (JSON)"
                              Grid.Column="1" Grid.Row="0" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Path:" Margin="0,0,8,6"/>
                    <TextBox x:Name="SuccessPathTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,8,6"/>
                    <Button x:Name="SuccessBrowseButton" Grid.Row="1" Grid.Column="2" Margin="0,0,6,6" MinWidth="70" Content="Browse" Click="SuccessBrowseButton_Click"/>
                    <Button x:Name="SuccessTestButton" Grid.Row="1" Grid.Column="3" Margin="0,0,0,6" MinWidth="70" Content="Test" Click="SuccessTestButton_Click"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Args:" Margin="0,0,8,0"/>
                    <TextBox x:Name="SuccessArgsTextBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"/>
                </Grid>
            </GroupBox>

            <GroupBox Header="On Error" Margin="0,0,0,8">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <CheckBox x:Name="ErrorEnabledCheckBox" Content="Enable" Grid.Column="0" Grid.Row="0" Margin="0,0,8,6"/>
                    <CheckBox x:Name="ErrorIncludeContextCheckBox" Content="Include copy context (JSON)"
                              Grid.Column="1" Grid.Row="0" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Path:" Margin="0,0,8,6"/>
                    <TextBox x:Name="ErrorPathTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,8,6"/>
                    <Button x:Name="ErrorBrowseButton" Grid.Row="1" Grid.Column="2" Margin="0,0,6,6" MinWidth="70" Content="Browse" Click="ErrorBrowseButton_Click"/>
                    <Button x:Name="ErrorTestButton" Grid.Row="1" Grid.Column="3" Margin="0,0,0,6" MinWidth="70" Content="Test" Click="ErrorTestButton_Click"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Args:" Margin="0,0,8,0"/>
                    <TextBox x:Name="ErrorArgsTextBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"/>
                </Grid>
            </GroupBox>

            <GroupBox Header="On Cancel">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <CheckBox x:Name="CancelEnabledCheckBox" Content="Enable" Grid.Column="0" Grid.Row="0" Margin="0,0,8,6"/>
                    <CheckBox x:Name="CancelIncludeContextCheckBox" Content="Include copy context (JSON)"
                              Grid.Column="1" Grid.Row="0" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Path:" Margin="0,0,8,6"/>
                    <TextBox x:Name="CancelPathTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,8,6"/>
                    <Button x:Name="CancelBrowseButton" Grid.Row="1" Grid.Column="2" Margin="0,0,6,6" MinWidth="70" Content="Browse" Click="CancelBrowseButton_Click"/>
                    <Button x:Name="CancelTestButton" Grid.Row="1" Grid.Column="3" Margin="0,0,0,6" MinWidth="70" Content="Test" Click="CancelTestButton_Click"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Args:" Margin="0,0,8,0"/>
                    <TextBox x:Name="CancelArgsTextBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"/>
                </Grid>
            </GroupBox>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="SaveButton" MinWidth="80" Margin="0,0,6,0" Content="Save" Click="SaveButton_Click"/>
            <Button x:Name="CloseButton" MinWidth="80" Content="Close" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
