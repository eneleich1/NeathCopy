<Window x:Class="NeathCopy.UsedWindows.VideoConversionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Video Conversion (FFmpeg)"
        Style="{DynamicResource UsedWindowStyle}"
        MinWidth="860"
        MinHeight="620"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        Icon="/NeathCopy;component/Brushes/Images/Light/settings.png"
        Closing="Window_Closing">
    <Grid Margin="8"
          Background="{DynamicResource ControlBackgroundBrush}"
          TextElement.Foreground="{DynamicResource TextBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Files" Grid.Row="0">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="Add Files" Width="90" Margin="0,0,8,0"
                            Command="{Binding AddFilesCommand}"/>
                    <Button Content="Remove Selected" Width="120" Margin="0,0,8,0"
                            Click="RemoveSelected_Click"/>
                    <Button Content="Clear List" Width="80"
                            Command="{Binding ClearListCommand}"/>
                    <TextBlock Margin="16,0,0,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextBrush}"
                               Text="Drag and drop video files here."/>
                </StackPanel>

                <ListView Grid.Row="1" Name="filesListView" AllowDrop="True" MinHeight="180"
                          SelectionMode="Extended"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          Drop="FilesListView_Drop" DragOver="FilesListView_DragOver"
                          ItemsSource="{Binding Items}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="FileName" Width="660">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2,0,2" HorizontalAlignment="Left">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="300"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="42"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Width="300"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding FileName}"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding FullPath}"/>
                                            <ProgressBar Grid.Column="1"
                                                         Width="120"
                                                         Height="12"
                                                         Margin="8,0,0,0"
                                                         VerticalAlignment="Center"
                                                         Minimum="0" Maximum="100"
                                                         Value="{Binding Progress}"
                                                         Foreground="{DynamicResource ProgressBarIndicatorBrush}"
                                                         Background="{DynamicResource ProgressBarTrackBrush}"/>
                                            <TextBlock Grid.Column="2"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextBrush}"
                                                           Text="{Binding Progress, StringFormat={}{0:F0}%}"/>
                                        </Grid>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Status" Width="110" DisplayMemberBinding="{Binding Status}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </GroupBox>

        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Conversion Settings">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Output format" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextBrush}"/>
                    <ComboBox Grid.Column="1" Width="140" HorizontalAlignment="Left"
                              Margin="0,0,0,6"
                              ItemsSource="{Binding OutputFormats}"
                              SelectedItem="{Binding SelectedOutputFormat}"/>

                    <TextBlock Grid.Row="1" Text="Bitrate (optional)" VerticalAlignment="Center"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource TextBrush}"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" Width="140" HorizontalAlignment="Left"
                              Margin="0,4,0,6"
                              IsEditable="True" Text="{Binding Bitrate, UpdateSourceTrigger=PropertyChanged}">
                        <ComboBoxItem Content="2000k"/>
                        <ComboBoxItem Content="3000k"/>
                        <ComboBoxItem Content="4000k"/>
                        <ComboBoxItem Content="5000k"/>
                        <ComboBoxItem Content="8000k"/>
                        <ComboBoxItem Content="12000k"/>
                    </ComboBox>

                    <TextBlock Grid.Row="2" Text="Resolution (optional)" VerticalAlignment="Center"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource TextBrush}"/>
                    <ComboBox Grid.Row="2" Grid.Column="1" Width="140" HorizontalAlignment="Left"
                              Margin="0,4,0,6"
                              IsEditable="True" Text="{Binding Resolution, UpdateSourceTrigger=PropertyChanged}">
                        <ComboBoxItem Content="640x480"/>
                        <ComboBoxItem Content="720x480"/>
                        <ComboBoxItem Content="1280x720"/>
                        <ComboBoxItem Content="1920x1080"/>
                    </ComboBox>

                    <TextBlock Grid.Row="3" Text="Output folder" VerticalAlignment="Center"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource TextBrush}"/>
                    <Grid Grid.Row="3" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Content="Browse..." Margin="8,0,0,0"
                                Command="{Binding BrowseOutputFolderCommand}"/>
                    </Grid>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="Parallelism" Margin="8,0,0,0">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Max parallel conversions"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBox Grid.Row="1" Width="80"
                             Text="{Binding MaxParallelText, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </GroupBox>
        </Grid>

        <GroupBox Grid.Row="2" Header="Progress" Margin="0,8,0,0">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Overall" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextBrush}"/>
                    <ProgressBar Minimum="0" Maximum="100" Height="16" Width="260"
                                 Value="{Binding OverallProgress}"
                                 Foreground="{DynamicResource ProgressBarIndicatorBrush}"
                                 Background="{DynamicResource ProgressBarTrackBrush}"/>
                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextBrush}"
                               Text="{Binding OverallProgress, StringFormat={}{0:F0}%}"/>
                </StackPanel>
                <TextBox Grid.Row="1" Margin="0,8,0,0" Height="150"
                         Text="{Binding LogText}"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         TextWrapping="Wrap" IsReadOnly="True"
                         TextChanged="LogTextBox_TextChanged"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Start Conversion" Width="120" Margin="0,0,8,0"
                    Command="{Binding StartConversionCommand}"/>
            <Button Content="Cancel" Width="80" Margin="0,0,8,0"
                    Command="{Binding CancelCommand}"/>
            <Button Content="Close" Width="80" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
