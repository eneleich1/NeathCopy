<Window x:Class="NeathCopy.UsedWindows.PackageCopierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Package Copier"
        Style="{DynamicResource UsedWindowStyle}"
        Width="920"
        Height="660"
        MinWidth="920"
        MinHeight="660"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Icon="/NeathCopy;component/Brushes/Images/Light/list.png"
        Closing="Window_Closing">
    <Grid Margin="8"
          Background="{DynamicResource ControlBackgroundBrush}"
          TextElement.Foreground="{DynamicResource TextBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <GroupBox Grid.Row="0" Grid.Column="0" Header="Sources" Margin="0,0,6,0">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <WrapPanel Margin="0,0,0,8">
                    <Button Content="Add Files" Width="90" Margin="0,0,8,0" Click="AddSourceFiles_Click"/>
                    <Button Content="Add Folder" Width="90" Margin="0,0,8,0" Click="AddSourceFolder_Click"/>
                    <Button Content="Remove Selected" Width="120" Margin="0,0,8,0" Click="RemoveSources_Click"/>
                    <Button Content="Clear" Width="70" Click="ClearSources_Click"/>
                </WrapPanel>

                <ListBox Grid.Row="1"
                         Name="sourcesListBox"
                         SelectionMode="Extended"
                         AllowDrop="True"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         DragOver="SourcesListBox_DragOver"
                         Drop="SourcesListBox_Drop"
                         ItemsSource="{Binding Sources}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Type}" FontWeight="Bold"/>
                                <TextBlock Grid.Column="1" Text="{Binding Path}" ToolTip="{Binding Path}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="0" Grid.Column="1" Header="Destinations" Margin="6,0,0,0">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <WrapPanel Margin="0,0,0,8">
                    <Button Content="Add Folder" Width="90" Margin="0,0,8,0" Click="AddDestination_Click"/>
                    <Button Content="Remove Selected" Width="120" Margin="0,0,8,0" Click="RemoveDestinations_Click"/>
                    <Button Content="Clear" Width="70" Click="ClearDestinations_Click"/>
                </WrapPanel>

                <ListBox Grid.Row="1"
                         Name="destinationsListBox"
                         SelectionMode="Extended"
                         AllowDrop="True"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         DragOver="DestinationsListBox_DragOver"
                         Drop="DestinationsListBox_Drop"
                         ItemsSource="{Binding Destinations}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Path}" ToolTip="{Binding Path}" Margin="0,2,0,2"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Header="Settings" Margin="0,8,0,0">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="Threads"/>
                <TextBox Grid.Column="1"
                         Margin="8,0,0,0"
                         Width="80"
                         HorizontalAlignment="Left"
                         Text="{Binding ThreadsText, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{Binding StatusText}" TextTrimming="CharacterEllipsis"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Header="Transfer" Margin="0,8,0,0">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="File:" Margin="0,0,8,0" VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="{Binding CurrentFileName, Mode=OneWay}" TextTrimming="CharacterEllipsis" ToolTip="{Binding CurrentFileName, Mode=OneWay}" VerticalAlignment="Center"/>
                </Grid>

                <Grid Grid.Row="1" Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="From:" Margin="0,0,8,0" VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="{Binding CurrentFromPath, Mode=OneWay}" TextTrimming="CharacterEllipsis" ToolTip="{Binding CurrentFromPath, Mode=OneWay}" VerticalAlignment="Center"/>
                </Grid>

                <Grid Grid.Row="2" Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="To:" Margin="0,0,8,0" VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="{Binding CurrentToPath, Mode=OneWay}" TextTrimming="CharacterEllipsis" ToolTip="{Binding CurrentToPath, Mode=OneWay}" VerticalAlignment="Center"/>
                </Grid>

                <Grid Grid.Row="3" Margin="0,8,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="{Binding PauseResumeButtonText, Mode=OneWay}" Width="90" Command="{Binding PauseResumeCommand}" Margin="0,0,8,0"/>
                    <Button Grid.Column="1" Content="Skip" Width="80" Command="{Binding SkipCommand}" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="Cancel" Width="80" Command="{Binding CancelCommand}" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="4" VerticalAlignment="Center" FontWeight="Bold" Text="{Binding SpeedText, Mode=OneWay}"/>
                </Grid>

                <ProgressBar Grid.Row="4"
                             Minimum="0"
                             Maximum="100"
                             Height="16"
                             Value="{Binding FilePercent, Mode=OneWay}"
                             Foreground="{DynamicResource ProgressBarIndicatorBrush}"
                             Background="{DynamicResource ProgressBarTrackBrush}"/>

                <Grid Grid.Row="5" Margin="0,2,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding FileProgressLeftText, Mode=OneWay}" HorizontalAlignment="Left"/>
                    <TextBlock Grid.Column="1" Text="{Binding FileProgressCenterText, Mode=OneWay}" HorizontalAlignment="Center" Margin="10,0"/>
                    <TextBlock Grid.Column="2" Text="{Binding FileProgressRightText, Mode=OneWay}" HorizontalAlignment="Right"/>
                </Grid>

                <ProgressBar Grid.Row="6"
                             Minimum="0"
                             Maximum="100"
                             Height="16"
                             Value="{Binding OverallPercent, Mode=OneWay}"
                             Foreground="{DynamicResource ProgressBarIndicatorBrush}"
                             Background="{DynamicResource ProgressBarTrackBrush}"/>

                <Grid Grid.Row="7" Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding OverallProgressLeftText, Mode=OneWay}" HorizontalAlignment="Left"/>
                    <TextBlock Grid.Column="1" Text="{Binding OverallProgressCenterText, Mode=OneWay}" HorizontalAlignment="Center" Margin="10,0"/>
                    <TextBlock Grid.Column="2" Text="{Binding OverallProgressRightText, Mode=OneWay}" HorizontalAlignment="Right"/>
                </Grid>

                <TextBox Grid.Row="8"
                         Margin="0,8,0,0"
                         Height="120"
                         IsReadOnly="True"
                         TextWrapping="NoWrap"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding LogText, Mode=OneWay}"
                         TextChanged="LogTextBox_TextChanged"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Start Copy" Width="110" Margin="0,0,8,0" Command="{Binding StartCommand}"/>
            <Button Content="Close" Width="90" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
