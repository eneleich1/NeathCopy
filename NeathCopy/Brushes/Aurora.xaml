<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>

    <!--MyBrushes-->
    <LinearGradientBrush x:Key="TitleBarBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF0A1C3A" Offset="0" />
        <GradientStop Color="#FF0E2F66" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="BorderBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF1A396B" Offset="0" />
        <GradientStop Color="#FF0B1B34" Offset="1" />
    </LinearGradientBrush>

    <!--Control Bakground-->
    <LinearGradientBrush x:Key="ControlBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#3300B2FF" Offset="0" />
        <GradientStop Color="#FF0A1C3A" Offset="0.12" />
        <GradientStop Color="#FF0E2F66" Offset="1" />
    </LinearGradientBrush>

    <!--Client Area Background-->
    <LinearGradientBrush x:Key="ClientAreaBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#2200B2FF" Offset="0" />
        <GradientStop Color="#FF0A1C3A" Offset="0.08" />
        <GradientStop Color="#FF0E2F66" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="TextBrush" Color="#F2F7FF" />

    <LinearGradientBrush x:Key="MenuBackground" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF0B1F3D" Offset="0" />
        <GradientStop Color="#FF0E2A5A" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ToolBarBackground" EndPoint="1,0.5" StartPoint="0,0.5">
        <GradientStop Color="#FF0B1F3D" Offset="0" />
        <GradientStop Color="#FF0E2F66" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ButtonMouseHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#332F8CFF" Offset="0" />
        <GradientStop Color="#11000000" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ProgressBarIndicatorBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF7FC3FF" Offset="0" />
        <GradientStop Color="#FF2F8CFF" Offset="0.45" />
        <GradientStop Color="#FF1B5BD3" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ProgressBarIndicatorBorderBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#66BFE4FF" Offset="0" />
        <GradientStop Color="#663A7CFF" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ProgressBarTrackBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientBrush.GradientStops>
            <GradientStopCollection>
                <GradientStop Color="#FF081326" Offset="0" />
                <GradientStop Color="#FF0C2142" Offset="1" />
            </GradientStopCollection>
        </GradientBrush.GradientStops>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ProgressBarTrackBorderBrush" Color="#1A6FA9"/>
    
    <!--Image Brushes-->
    <ImageBrush x:Key="settingsBrush" Stretch="Uniform" ImageSource="Images/Dark/settings.png">
        <ImageBrush.RelativeTransform>
            <TransformGroup>
                <ScaleTransform CenterY="0.5" CenterX="0.5" ScaleX="1.5" ScaleY="1.5"/>
                <SkewTransform CenterY="0.5" CenterX="0.5"/>
                <RotateTransform CenterY="0.5" CenterX="0.5"/>
                <TranslateTransform/>
            </TransformGroup>
        </ImageBrush.RelativeTransform>
    </ImageBrush>
    <ImageBrush x:Key="moveUpBrush" ImageSource="Images/Dark/move_up.png">
        <ImageBrush.RelativeTransform>
            <TransformGroup>
                <ScaleTransform CenterY="0.5" CenterX="0.5" ScaleX="1.5" ScaleY="1.5"/>
                <SkewTransform CenterY="0.5" CenterX="0.5"/>
                <RotateTransform CenterY="0.5" CenterX="0.5"/>
                <TranslateTransform/>
            </TransformGroup>
        </ImageBrush.RelativeTransform>
    </ImageBrush>
    <ImageBrush x:Key="moveDownBrush" ImageSource="Images/Dark/move_down.png">
        <ImageBrush.RelativeTransform>
            <TransformGroup>
                <ScaleTransform CenterY="0.5" CenterX="0.5" ScaleX="1.5" ScaleY="1.5"/>
                <SkewTransform CenterY="0.5" CenterX="0.5"/>
                <RotateTransform CenterY="0.5" CenterX="0.5"/>
                <TranslateTransform/>
            </TransformGroup>
        </ImageBrush.RelativeTransform>
    </ImageBrush>
    <ImageBrush x:Key="moveFirstBrush" ImageSource="Images/Dark/move_first.png">
        <ImageBrush.RelativeTransform>
            <TransformGroup>
                <ScaleTransform CenterY="0.5" CenterX="0.5" ScaleX="1.5" ScaleY="1.5"/>
                <SkewTransform CenterY="0.5" CenterX="0.5"/>
                <RotateTransform CenterY="0.5" CenterX="0.5"/>
                <TranslateTransform/>
            </TransformGroup>
        </ImageBrush.RelativeTransform>
    </ImageBrush>
    <ImageBrush x:Key="moveLastBrush" ImageSource="Images/Dark/move_last.png">
        <ImageBrush.RelativeTransform>
            <TransformGroup>
                <ScaleTransform CenterY="0.5" CenterX="0.5" ScaleX="1.5" ScaleY="1.5"/>
                <SkewTransform CenterY="0.5" CenterX="0.5"/>
                <RotateTransform CenterY="0.5" CenterX="0.5"/>
                <TranslateTransform/>
            </TransformGroup>
        </ImageBrush.RelativeTransform>
    </ImageBrush>
    <ImageBrush x:Key="loadListBrush" ImageSource="Images/Dark/load_list.png">
        <ImageBrush.RelativeTransform>
            <TransformGroup>
                <ScaleTransform CenterY="0.5" CenterX="0.5" ScaleX="1.5" ScaleY="1.5"/>
                <SkewTransform CenterY="0.5" CenterX="0.5"/>
                <RotateTransform CenterY="0.5" CenterX="0.5"/>
                <TranslateTransform/>
            </TransformGroup>
        </ImageBrush.RelativeTransform>
    </ImageBrush>
    <ImageBrush x:Key="saveListBrush" ImageSource="Images/Dark/save.png">
        <ImageBrush.RelativeTransform>
            <TransformGroup>
                <ScaleTransform CenterY="0.5" CenterX="0.5" ScaleX="1.5" ScaleY="1.5"/>
                <SkewTransform CenterY="0.5" CenterX="0.5"/>
                <RotateTransform CenterY="0.5" CenterX="0.5"/>
                <TranslateTransform/>
            </TransformGroup>
        </ImageBrush.RelativeTransform>
    </ImageBrush>
    <ImageBrush x:Key="removeFromListBrush" ImageSource="Images/Dark/remove.png">
        <ImageBrush.RelativeTransform>
            <TransformGroup>
                <ScaleTransform CenterY="0.5" CenterX="0.5" ScaleX="1.5" ScaleY="1.5"/>
                <SkewTransform CenterY="0.5" CenterX="0.5"/>
                <RotateTransform CenterY="0.5" CenterX="0.5"/>
                <TranslateTransform/>
            </TransformGroup>
        </ImageBrush.RelativeTransform>
    </ImageBrush>

    <ImageBrush x:Key="moreBrush" ImageSource="Images/Dark/more.png" Stretch="Uniform"/>
    <ImageBrush x:Key="pauseBrush" ImageSource="Images/Dark/pause.png" Stretch="Uniform"/>
    <ImageBrush x:Key="resumeStartBrush" ImageSource="Images/Dark/resume.png" Stretch="Uniform"/>
    <ImageBrush x:Key="skipBrush" ImageSource="Images/Dark/skip.png" Stretch="Uniform"/>
    <ImageBrush x:Key="cancelBrush" ImageSource="Images/Dark/cancel_zoom.png" Stretch="Uniform"/>
    
    <!--Microsoft Brushes-->
    <LinearGradientBrush x:Key="NormalBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientBrush.GradientStops>
            <GradientStopCollection>
                <GradientStop Color="#FF1B3D6E" Offset="0.0"/>
                <GradientStop Color="#FF0B1E3B" Offset="1.0"/>
            </GradientStopCollection>
        </GradientBrush.GradientStops>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="LightBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientBrush.GradientStops>
            <GradientStopCollection>
                <GradientStop Color="#FF2A5A95" Offset="0.0"/>
                <GradientStop Color="#FF122B4F" Offset="1.0"/>
            </GradientStopCollection>
        </GradientBrush.GradientStops>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PressedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientBrush.GradientStops>
            <GradientStopCollection>
                <GradientStop Color="#FF2F8CFF" Offset="0.0"/>
                <GradientStop Color="#FF1E5AC9" Offset="0.55"/>
                <GradientStop Color="#FF12306E" Offset="1.0"/>
            </GradientStopCollection>
        </GradientBrush.GradientStops>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="DisabledForegroundBrush" Color="#99A7C1" />

    <SolidColorBrush x:Key="DisabledBackgroundBrush" Color="#FF0A1C3A" />

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF0A1C3A" />

    <SolidColorBrush x:Key="SelectedBackgroundBrush" Color="#FF2F8CFF" />

    <!-- Miscellaneous Brushes -->
    <SolidColorBrush x:Key="GlyphBrush" Color="#FFB8D8FF" />

    <SolidColorBrush x:Key="LightColorBrush" Color="#FF2F8CFF" />
    

</ResourceDictionary>
