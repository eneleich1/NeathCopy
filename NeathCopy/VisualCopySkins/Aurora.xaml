
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:tools="clr-namespace:NeathCopy.Tools"
                    xmlns:local="clr-namespace:NeathCopy"
                    xmlns:res="clr-namespace:NeathCopy.Resources">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/NeathCopy;component/Resources/ProgressBar.xaml"/>
        <ResourceDictionary Source="/NeathCopy;component/Resources/Button.xaml"/>
        <ResourceDictionary Source="/NeathCopy;component/Resources/Menu.xaml"/>
        <ResourceDictionary Source="/NeathCopy;component/Resources/ViewModelsDictionary.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <res:TargetDeviceNameConverter x:Key="TargetDeviceNameConverter"/>
    <res:TargetDeviceSizeConverter x:Key="TargetDeviceSizeConverter"/>

    <Style TargetType="TextBlock" x:Key="InfoLabelStyle">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="Opacity" Value="0.9"/>
    </Style>

    <Style TargetType="TextBlock" x:Key="InfoValueStyle">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="14.5"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="LineHeight" Value="18"/>
    </Style>

    <Style TargetType="TextBlock" x:Key="SmallInfoStyle">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="Opacity" Value="0.85"/>
        <Setter Property="LineHeight" Value="15"/>
    </Style>

    <Style TargetType="TextBlock" x:Key="SpeedValueStyle">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="19"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
    </Style>

    <Style TargetType="TextBlock" x:Key="DeviceTitleStyle">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
    </Style>

    <Style TargetType="Border" x:Key="AuroraCardStyle">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FF0B1F3D" Offset="0"/>
                    <GradientStop Color="#FF0B234A" Offset="0.5"/>
                    <GradientStop Color="#FF0E2A5A" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="#4069B6FF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#1E335A" Opacity="0.55"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ProgressBar" x:Key="AuroraMainProgressStyle">
        <Setter Property="Background" Value="{DynamicResource ProgressBarTrackBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ProgressBarIndicatorBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ProgressBar}">
                    <Grid>
                        <Border x:Name="PART_Track" CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#2A6FA9"
                                BorderThickness="1"/>
                        <Border x:Name="PART_Indicator" CornerRadius="6" Margin="1"
                                Background="{TemplateBinding Foreground}"
                                HorizontalAlignment="Left">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#4DB8FF" Opacity="0.75"/>
                            </Border.Effect>
                            <Grid ClipToBounds="True">
                                <Rectangle Height="2.2" VerticalAlignment="Top" Opacity="0.75">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#D8FFFFFF" Offset="0"/>
                                            <GradientStop Color="#33FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <Rectangle Opacity="0.55">
                                    <Rectangle.Fill>
                                        <RadialGradientBrush GradientOrigin="0.08,0.5" RadiusX="0.85" RadiusY="0.85">
                                            <GradientStop Color="#80A6D3FF" Offset="0"/>
                                            <GradientStop Color="#0096C9FF" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                            </Grid>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ProgressBar" x:Key="AuroraOverallProgressStyle">
        <Setter Property="Background" Value="{DynamicResource ProgressBarTrackBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ProgressBarIndicatorBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ProgressBar}">
                    <Grid>
                        <Border x:Name="PART_Track" CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#245B8A"
                                BorderThickness="1"/>
                        <Border x:Name="PART_Indicator" CornerRadius="4" Margin="1"
                                Background="{TemplateBinding Foreground}"
                                HorizontalAlignment="Left">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" ShadowDepth="0" Color="#3FA7FF" Opacity="0.45"/>
                            </Border.Effect>
                            <Grid ClipToBounds="True">
                                <Rectangle Height="1.2" VerticalAlignment="Top" Opacity="0.55">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#B3FFFFFF" Offset="0"/>
                                            <GradientStop Color="#22FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                            </Grid>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ProgressBar" x:Key="AuroraDeviceMiniProgressStyle">
        <Setter Property="Background" Value="{DynamicResource ProgressBarTrackBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ProgressBarIndicatorBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ProgressBar}">
                    <Grid>
                        <Border x:Name="PART_Track" CornerRadius="3"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource ProgressBarTrackBorderBrush}"
                                BorderThickness="1"/>
                        <Border x:Name="PART_Indicator" CornerRadius="3" Margin="1"
                                Background="{TemplateBinding Foreground}"
                                HorizontalAlignment="Left"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button" x:Key="AuroraIconButtonStyle">
        <Setter Property="Width" Value="54"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="Background" Value="#1F2A4A"/>
        <Setter Property="BorderBrush" Value="#553A6AB4"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border CornerRadius="10"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid>
                            <Border CornerRadius="10" Margin="1" Opacity="0.45">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#33FFFFFF" Offset="0"/>
                                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#24345A"/>
                            <Setter Property="BorderBrush" Value="#667FC5FF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#1A2543"/>
                            <Setter Property="BorderBrush" Value="#88A6D3FF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Geometry x:Key="AuroraIconList">M 3 6 L 21 6 M 3 12 L 21 12 M 3 18 L 21 18</Geometry>
    <Geometry x:Key="AuroraIconPause">M 6 5 L 10 5 L 10 19 L 6 19 Z M 14 5 L 18 5 L 18 19 L 14 19 Z</Geometry>
    <Geometry x:Key="AuroraIconPlay">M 7 5 L 19 12 L 7 19 Z</Geometry>
    <Geometry x:Key="AuroraIconSkip">M 5 5 L 14 12 L 5 19 Z M 16 5 L 19 5 L 19 19 L 16 19 Z</Geometry>
    <Geometry x:Key="AuroraIconCancelX">M 6 6 L 18 18 M 18 6 L 6 18</Geometry>
    <Geometry x:Key="AuroraIconChevron">M 4 8 L 12 16 L 20 8</Geometry>

    <Style TargetType="Path" x:Key="AuroraPauseIconStyle">
        <Setter Property="Data" Value="{StaticResource AuroraIconPause}"/>
        <Setter Property="Fill" Value="{DynamicResource TextBrush}"/>
        <Setter Property="Stretch" Value="Uniform"/>
        <Setter Property="Width" Value="22"/>
        <Setter Property="Height" Value="22"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding State}" Value="{x:Static local:VisualCopy+VisualCopyState.Paused}">
                <Setter Property="Data" Value="{StaticResource AuroraIconPlay}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding State}" Value="{x:Static local:VisualCopy+VisualCopyState.None}">
                <Setter Property="Data" Value="{StaticResource AuroraIconPlay}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding State}" Value="{x:Static local:VisualCopy+VisualCopyState.Finished}">
                <Setter Property="Data" Value="{StaticResource AuroraIconPlay}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="Expander" x:Key="AuroraExpanderStyle">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Expander">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ToggleButton x:Name="HeaderSite" Background="Transparent" BorderThickness="0" Padding="0" Focusable="False"
                                      IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="20" Height="20" CornerRadius="10" Grid.Column="0" Background="#1B294D" BorderBrush="#3A6AB4" BorderThickness="1">
                                    <Path x:Name="Chevron" Data="{StaticResource AuroraIconChevron}" Stroke="{DynamicResource TextBrush}" StrokeThickness="2"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="0" CenterX="6" CenterY="6"/>
                                        </Path.RenderTransform>
                                    </Path>
                                </Border>
                                <ContentPresenter Grid.Column="1" ContentSource="Header" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                <Rectangle Grid.Column="2" Height="1" VerticalAlignment="Center" Margin="16,0,0,0" Opacity="0.35">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#66A6D3FF" Offset="0"/>
                                            <GradientStop Color="#00A6D3FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                            </Grid>
                        </ToggleButton>
                        <ContentPresenter x:Name="ExpandSite" Grid.Row="1" Visibility="Collapsed" Margin="0,10,0,0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="true">
                            <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="Chevron" Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="180" CenterX="6" CenterY="6"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Control" x:Key="VisualCopyStyle">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Background="{DynamicResource ClientAreaBackgroundBrush}"
                            Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid x:Name="AuroraRoot" Margin="16" Width="660" Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="340"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="File:" Style="{DynamicResource InfoLabelStyle}" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding CurrentFile.Name, StringFormat=0}" Style="{DynamicResource InfoValueStyle}" FontSize="15.5" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="From:" Style="{DynamicResource InfoLabelStyle}" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding From, StringFormat=0}" Style="{DynamicResource InfoValueStyle}" FontSize="14"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <Grid Grid.Row="2" Margin="0,0,0,10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ProgressBar Grid.Column="0"
                                                         Height="8"
                                                         Value="{Binding SinglePorcent}"
                                                         Style="{DynamicResource AuroraMainProgressStyle}"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SinglePorcent, StringFormat={}{0:0.0}%}" Style="{DynamicResource SmallInfoStyle}"/>
                                                <Path Data="{StaticResource AuroraIconChevron}" Stroke="{DynamicResource TextBrush}" StrokeThickness="1.5"
                                                      Width="10" Height="10" Margin="6,2,0,0" Opacity="0.6"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Grid.Row="1" Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding CurrentFileSizeTransferred, StringFormat=0}"
                                                       Style="{DynamicResource SmallInfoStyle}" />
                                            <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Right">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding FilesCount}" Style="{DynamicResource SmallInfoStyle}"/>
                                                    <TextBlock Text="   |   " Style="{DynamicResource SmallInfoStyle}"/>
                                                    <TextBlock Text="{Binding ElapsedTime, StringFormat={}{0}}" Style="{DynamicResource SmallInfoStyle}"/>
                                                </StackPanel>
                                                <TextBlock Margin="0,4,0,0" Style="{DynamicResource SmallInfoStyle}">
                                                    <Run Text="Remaining: "/>
                                                    <Run Text="{Binding RemainingTime}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>

                                    <Grid Grid.Row="3" Margin="0,0,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <ProgressBar Grid.Row="0"
                                                     Height="4"
                                                     Margin="0,0,-18,0"
                                                     Value="{Binding OverallPorcent}"
                                                     Style="{DynamicResource AuroraOverallProgressStyle}"/>

                                        <TextBlock Grid.Row="1"
                                                   Margin="0,8,0,0"
                                                   Text="{Binding OverallSizeTransferred, StringFormat=0}"
                                                   Style="{DynamicResource SmallInfoStyle}" />
                                    </Grid>
                                </Grid>

                                <Grid Grid.Column="1" Margin="20,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,4,0,18" Width="250" HorizontalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Speed:" Style="{DynamicResource InfoLabelStyle}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SpeedInfo, StringFormat=0}" Style="{DynamicResource SpeedValueStyle}"
                                                   HorizontalAlignment="Right" TextAlignment="Right" VerticalAlignment="Center"/>
                                        <Border Grid.ColumnSpan="2" Height="2" VerticalAlignment="Bottom" Margin="0,18,0,0" Opacity="0.35">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#66A6D3FF" Offset="0"/>
                                                    <GradientStop Color="#00A6D3FF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                    </Grid>

                                    <Border Grid.Row="1" Padding="12" CornerRadius="12" Style="{DynamicResource AuroraCardStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Image Grid.Column="0" Width="32" Height="32" Source="Images/Advance2017/hdd.png" Margin="0,0,10,0"/>
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                       Text="{Binding TargetDevice, Converter={StaticResource TargetDeviceNameConverter}}"
                                                       Style="{DynamicResource DeviceTitleStyle}"/>
                                            <ProgressBar Grid.Column="2" Height="4" Width="100" Margin="10,0,10,0" VerticalAlignment="Center"
                                                         Value="{Binding DriverSizePorcent}" Foreground="{Binding DriverSizeBrush}"
                                                         Style="{DynamicResource AuroraDeviceMiniProgressStyle}"/>
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding TargetDevice, Converter={StaticResource TargetDeviceSizeConverter}}"
                                                       Style="{DynamicResource SmallInfoStyle}"
                                                       VerticalAlignment="Center"/>

                                            <Border Grid.ColumnSpan="4" CornerRadius="10" Margin="-4,-4,-4,0" Height="12" VerticalAlignment="Top" Opacity="0.25" IsHitTestVisible="False">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#66FFFFFF" Offset="0"/>
                                                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="3" Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Width="54" Height="44" Style="{DynamicResource AuroraIconButtonStyle}" Command="{x:Static tools:MyCommands.MoreCommand}" Name="list_bt" ToolTip="File List">
                                            <Path Data="{StaticResource AuroraIconList}" Stroke="{DynamicResource TextBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Stretch="Uniform" Width="22" Height="22"/>
                                        </Button>
                                        <Button Grid.Column="1" Width="54" Height="44" Margin="10,0,0,0" Style="{DynamicResource AuroraIconButtonStyle}" Command="{x:Static tools:MyCommands.PauseCommand}" Name="pauseResume_bt" ToolTip="Pause/Resume">
                                            <Path Style="{StaticResource AuroraPauseIconStyle}"/>
                                        </Button>
                                        <Button Grid.Column="2" Width="54" Height="44" Margin="10,0,0,0" Style="{DynamicResource AuroraIconButtonStyle}" Command="{x:Static tools:MyCommands.SkipCommand}" ToolTip="Skip">
                                            <Path Data="{StaticResource AuroraIconSkip}" Fill="{DynamicResource TextBrush}" Stretch="Uniform" Width="22" Height="22"/>
                                        </Button>
                                        <Button Grid.Column="3" Width="54" Height="44" Margin="10,0,0,0" Style="{DynamicResource AuroraIconButtonStyle}" Command="{x:Static tools:MyCommands.CancelCommand}" Name="cancel_bt" ToolTip="Cancel">
                                            <Path Data="{StaticResource AuroraIconCancelX}" Stroke="{DynamicResource TextBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Stretch="Uniform" Width="20" Height="20"/>
                                        </Button>
                                        <TextBlock Grid.Column="4" Margin="16,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12.5" FontWeight="SemiBold" Style="{DynamicResource SmallInfoStyle}">
                                            <Run Text="Operation: "/>
                                            <Run Text="{Binding Operation, StringFormat=0}"/>
                                        </TextBlock>
                                    </Grid>
                                </Grid>

                                <Rectangle Grid.Column="0" Grid.RowSpan="3" HorizontalAlignment="Right" Width="1" Margin="8,0,8,0" Opacity="0.25">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#66A6D3FF" Offset="0"/>
                                            <GradientStop Color="#00A6D3FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>

                                <Border Grid.Column="1" Height="2" VerticalAlignment="Top" Margin="0,0,0,0" Opacity="0.4">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#66A6D3FF" Offset="0"/>
                                            <GradientStop Color="#00A6D3FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Grid>

                            <Expander Grid.Row="1" Margin="16,2,16,6" Header="{DynamicResource t14}"
                                      Foreground="{DynamicResource TextBrush}" Style="{StaticResource AuroraExpanderStyle}" ExpandDirection="Down">
                                <Border CornerRadius="14" Padding="12" Style="{DynamicResource AuroraCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Rectangle Grid.Column="0" Grid.RowSpan="6" Width="1" HorizontalAlignment="Right" Margin="0,4,8,4" Opacity="0.2">
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#66A6D3FF" Offset="0"/>
                                                    <GradientStop Color="#00A6D3FF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>

                                        <Grid Grid.Row="0" Grid.Column="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Width="4" Height="4" Fill="#7FB3FF" Margin="0,6,8,0"/>
                                            <TextBlock Grid.Column="1" Text="Enqueue Number:" Style="{DynamicResource SmallInfoStyle}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding InqueueNumber, StringFormat=0}" Style="{DynamicResource InfoValueStyle}" Margin="8,0,0,0"/>
                                        </Grid>
                                        <Grid Grid.Row="1" Grid.Column="0" Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Width="4" Height="4" Fill="#7FB3FF" Margin="0,6,8,0"/>
                                            <TextBlock Grid.Column="1" Text="Operation:" Style="{DynamicResource SmallInfoStyle}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Operation, StringFormat=0}" Style="{DynamicResource InfoValueStyle}" Margin="8,0,0,0"/>
                                        </Grid>
                                        <Grid Grid.Row="2" Grid.Column="0" Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Width="4" Height="4" Fill="#7FB3FF" Margin="0,6,8,0"/>
                                            <TextBlock Grid.Column="1" Text="Copy Option:" Style="{DynamicResource SmallInfoStyle}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding CopyOption, StringFormat=0}" Style="{DynamicResource InfoValueStyle}" Margin="8,0,0,0"/>
                                        </Grid>
                                        <Grid Grid.Row="3" Grid.Column="0" Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Width="4" Height="4" Fill="#7FB3FF" Margin="0,6,8,0"/>
                                            <TextBlock Grid.Column="1" Text="File:" Style="{DynamicResource SmallInfoStyle}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding CurrentFile.Name, StringFormat=0}" Style="{DynamicResource InfoValueStyle}" Margin="8,0,0,0"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                        <Grid Grid.Row="4" Grid.Column="0" Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Width="4" Height="4" Fill="#7FB3FF" Margin="0,6,8,0"/>
                                            <TextBlock Grid.Column="1" Text="From:" Style="{DynamicResource SmallInfoStyle}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding From, StringFormat=0}" Style="{DynamicResource InfoValueStyle}" Margin="8,0,0,0"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                        <Grid Grid.Row="5" Grid.Column="0" Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Width="4" Height="4" Fill="#7FB3FF" Margin="0,6,8,0"/>
                                            <TextBlock Grid.Column="1" Text="To:" Style="{DynamicResource SmallInfoStyle}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding To, StringFormat=0}" Style="{DynamicResource InfoValueStyle}" Margin="8,0,0,0"
                                                       ToolTip="{Binding ToToolTip, StringFormat=0}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>

                                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left">
                                            <TextBlock Text="Elapsed Time:" Style="{DynamicResource SmallInfoStyle}"/>
                                            <TextBlock Text="{Binding ElapsedTime, StringFormat={}{0}}" Style="{DynamicResource InfoValueStyle}" Margin="8,0,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="Remaining Time:" Style="{DynamicResource SmallInfoStyle}"/>
                                            <TextBlock Text="{Binding RemainingTime, StringFormat={}{0}}" Style="{DynamicResource InfoValueStyle}" Margin="8,0,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="Files in Queue:" Style="{DynamicResource SmallInfoStyle}"/>
                                            <TextBlock Text="{Binding FilesCount}" Style="{DynamicResource InfoValueStyle}" Margin="8,0,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="Current File:" Style="{DynamicResource SmallInfoStyle}"/>
                                            <TextBlock Text="{Binding CurrentFile.Name, StringFormat=0}" Style="{DynamicResource InfoValueStyle}" Margin="8,0,0,0"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <ProgressBar Grid.Row="4" Grid.Column="1" Height="4" Margin="0,8,0,0"
                                                     Value="{Binding SinglePorcent}" Style="{DynamicResource AuroraOverallProgressStyle}"/>
                                    </Grid>
                                </Border>
                            </Expander>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
